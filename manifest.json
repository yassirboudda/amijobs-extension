{
  "manifest_version": 3,
  "name": "AmiJobs",
  "version": "1.2.2",
  "description": "Auto-apply to jobs across multiple job-application websites with AI-assisted form filling.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://www.hellowork.com/*",
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://fr.indeed.com/*",
    "https://*.indeed.com/*",
    "https://smartapply.indeed.com/*",
    "https://www.glassdoor.com/*",
    "https://www.glassdoor.fr/*",
    "https://*.glassdoor.com/*",
    "https://api.mistral.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.hellowork.com/fr-fr/*"
      ],
      "js": [
        "content/hellowork.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "content/linkedin.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.indeed.com/*",
        "https://fr.indeed.com/*",
        "https://*.indeed.com/*"
      ],
      "js": [
        "content/shared-autofill.js",
        "content/indeed.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.glassdoor.com/*",
        "https://www.glassdoor.fr/*",
        "https://*.glassdoor.com/*"
      ],
      "js": [
        "content/shared-autofill.js",
        "content/glassdoor.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AmiJobs",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
